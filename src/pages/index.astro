---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nordicpup - Kommer Snart">
  <section class="flex flex-col items-center justify-center text-center py-12 sm:py-20">
    <p class="uppercase tracking-[0.3em] text-accent text-sm font-medium mb-6">Kommer snart</p>
    <h1 class="mb-6">
      <img src="/logo.png" alt="Nordicpup Logo" class="h-16 sm:h-24">
    </h1>
    <p class="text-lg sm:text-xl text-white/70 max-w-2xl mb-12 leading-relaxed">
      Skandinavisk design för din bästa vän. Stilrena och hållbara hundaccessoarer — sele, koppel, halsband och flugor — för den moderna hunden. Vi kommer även erbjuda unika lyxprodukter som för tillfället inte finns i Skandinavien.
    </p>

    <div class="w-full max-w-md mb-8">
      <p class="text-white/60 text-sm mb-4">Få reda på när vi lanserar</p>
      <form id="notify-form" class="flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          name="email"
          placeholder="Din e-postadress"
          required
          class="flex-1 px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition"
        />
        <button type="submit" class="btn">Prenumerera</button>
      </form>
      <p id="notify-success" class="text-green-400 mt-2 hidden">Tack! Du är nu prenumerant 🎉</p>
    </div>
  </section>
</Layout>

<script>
const LIST_ID = "3edfa6f6-22cf-11f1-b3f0-3bda711e24fc"; // Your EmailOctopus list ID
const API_KEY = "eo_ca40f8c218ec500da0322ef8027f47adf656c6d9a1b56493102e40ab1c28a0b8"; // Your API key

document.getElementById("notify-form").addEventListener("submit", async (e) => {
  e.preventDefault();
  const emailInput = e.target.querySelector("input[name='email']");
  const email = emailInput.value;
  const successMsg = document.getElementById("notify-success");

  try {
    const response = await fetch(`https://api.emailoctopus.com/lists/${LIST_ID}/contacts`, {
      method: "PUT", // v2 uses PUT for upsert (create or update)
      headers: {
        "Content-Type": "application/json",
        "Authorization": `Bearer ${API_KEY}`
      },
      body: JSON.stringify({
        email_address: email,
        status: "subscribed"
      })
    });

    if (response.ok) {
      emailInput.value = "";
      successMsg.classList.remove("hidden");
      setTimeout(() => successMsg.classList.add("hidden"), 5000); // hide after 5s
    } else {
      const error = await response.json();
      console.error(error);
      alert("Något gick fel, försök igen.");
    }
  } catch (err) {
    console.error(err);
    alert("Något gick fel, försök igen.");
  }
});
</script>
