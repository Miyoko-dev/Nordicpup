---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nordicpup - Kommer Snart">
  <section class="flex flex-col items-center justify-center text-center py-12 sm:py-20">
    <p class="uppercase tracking-[0.3em] text-accent text-sm font-medium mb-6">Kommer snart</p>
    <h1 class="mb-6">
      <img src="/logo.png" alt="Nordicpup Logo" class="h-16 sm:h-24">
    </h1>
    <p class="text-lg sm:text-xl text-white/70 max-w-2xl mb-12 leading-relaxed">
      Skandinavisk design för din bästa vän. Stilrena och hållbara hundaccessoarer — sele, koppel, halsband och flugor — för den moderna hunden. Vi kommer även erbjuda unika lyxprodukter som för tillfället inte finns i Skandinavien.
    </p>

    <div class="w-full max-w-md mb-8">
      <p class="text-white/60 text-sm mb-4">Få reda på när vi lanserar</p>
      <form name="notify" class="flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          placeholder="Din e-postadress"
          required
          class="flex-1 px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition"
        />
        <button type="submit" class="btn">Prenumerera</button>
      </form>
    </div>
  </section>
</Layout>

<!-- EmailOctopus script -->
<script async src="https://eocampaign1.com/form/3edfa6f6-22cf-11f1-b3f0-3bda711e24fc.js" data-form="3edfa6f6-22cf-11f1-b3f0-3bda711e24fc"></script>

<!-- Hide the injected EmailOctopus form -->
<style>
  .eo-form-container {
    position: absolute;
    left: -9999px;
    opacity: 0;
    pointer-events: none;
  }
</style>

<!-- Connect your visible form to the hidden EmailOctopus form -->
<script>
window.addEventListener("load", () => {
  const yourForm = document.querySelector("form[name='notify']");

  // Poll every 200ms until the hidden form is injected
  const waitForEOForm = setInterval(() => {
    const eoForm = document.querySelector(".eo-form-container form");
    const eoEmail = document.querySelector(".eo-form-container input[type='email']");

    if (eoForm && eoEmail) {
      clearInterval(waitForEOForm);

      yourForm.addEventListener("submit", (e) => {
        e.preventDefault();
        const email = yourForm.querySelector("input[type='email']").value;

        eoEmail.value = email;
        eoForm.submit();

        // UX feedback
        yourForm.reset();
        alert("Tack! Kolla din mail 📩");
      });
    }
  }, 200);
});
</script>
