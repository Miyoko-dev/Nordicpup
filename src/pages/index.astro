---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nordicpup - Kommer Snart">
    <section class="flex flex-col items-center justify-center text-center py-12 sm:py-20">
        <p class="uppercase tracking-[0.3em] text-accent text-sm font-medium mb-6">Kommer snart</p>
        <h1 class="mb-6">
            <img src="/logo.png" alt="Nordicpup Logo" class="h-16 sm:h-24">
        </h1>
        <p class="text-lg sm:text-xl text-white/70 max-w-2xl mb-12 leading-relaxed">
            Skandinavisk design för din bästa vän. Stilrena och hållbara hundaccessoarer — sele, koppel, halsband och flugor — för den moderna hunden. Vi kommer även erbjuda unika lyxprodukter som för tillfället inte finns i Skandinavien.
        </p>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6 mb-16 w-full max-w-2xl">
            <div class="product-card">
                <div class="product-icon">
                    <!-- Harness icon -->
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8">
                        <path d="M12 3C8 3 5 6 5 10v2l-2 3v1h18v-1l-2-3v-2c0-4-3-7-7-7z"/>
                        <path d="M8 16v2a4 4 0 0 0 8 0v-2"/>
                        <path d="M12 3v7"/>
                        <path d="M8 10h8"/>
                    </svg>
                </div>
                <span class="product-label">Sele</span>
            </div>
            <div class="product-card">
                <div class="product-icon">
                    <!-- Leash icon -->
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8">
                        <path d="M18 4a2 2 0 1 1 0 4 2 2 0 0 1 0-4z"/>
                        <path d="M18 8c0 3-2 5-4 7s-4 5-4 5"/>
                        <path d="M7 22a2 2 0 1 1 0-4 2 2 0 0 1 0 4z"/>
                    </svg>
                </div>
                <span class="product-label">Koppel</span>
            </div>
            <div class="product-card">
                <div class="product-icon">
                    <!-- Collar icon -->
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8">
                        <ellipse cx="12" cy="12" rx="10" ry="5"/>
                        <ellipse cx="12" cy="12" rx="7" ry="3"/>
                        <circle cx="12" cy="17" r="1" fill="currentColor"/>
                    </svg>
                </div>
                <span class="product-label">Halsband</span>
            </div>
            <div class="product-card">
                <div class="product-icon">
                    <!-- Bow tie icon -->
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8">
                        <path d="M12 12L4 6v12l8-6zM12 12l8-6v12l-8-6z"/>
                        <circle cx="12" cy="12" r="2" fill="currentColor"/>
                    </svg>
                </div>
                <span class="product-label">Fluga</span>
            </div>
        </div>

        <div class="w-full max-w-md mb-8">
            <p class="text-white/60 text-sm mb-4">Få reda på när vi lanserar</p>
            <form name="notify" method="POST" data-netlify="true" class="flex flex-col sm:flex-row gap-3">
                <input type="hidden" name="form-name" value="notify" />
                <input
                    type="email"
                    name="email"
                    placeholder="Din e-postadress"
                    required
                    class="flex-1 px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition"
                />
                <button type="submit" class="btn">Prenumerera</button>
            </form>
        </div>

        <div class="flex items-center gap-2 text-white/40 text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Designat i Skandinavien</span>
        </div>
    </section>
</Layout>
